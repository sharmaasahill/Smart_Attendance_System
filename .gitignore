# ===========================================
# Smart Attendance System — .gitignore
# ===========================================

# ============ Python ============
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
env/
.venv/
ENV/

# ============ React / Frontend ============
node_modules/
package-lock.json

# Production builds
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============ Database ============
*.db
*.sqlite
*.sqlite3

# ============ Face Recognition Data ============
# User face images and encodings (biometric data — never commit)
backend/dataset/
backend/uploads/
*.pkl
encoding*.json

# ============ Environment Variables ============
.env
.env.local
.env.development
.env.production

# ============ IDE / Editor ============
# Note: .vscode/settings.json is kept to share interpreter settings with teammates
.idea/
*.swp
*.swo
*~

# ============ OS Files ============
.DS_Store
Thumbs.db
Desktop.ini
