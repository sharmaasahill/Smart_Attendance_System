# Smart Attendance System - Backend Environment
# Copy to .env and fill in real values. NEVER commit the .env file.

# ----- App -----
DEBUG=false

# ----- Security -----
# Generate a strong key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin email - this user is assigned the admin role on registration
ADMIN_EMAIL=your-admin-email@example.com

# ----- CORS (comma-separated origins allowed to call the API) -----
BACKEND_CORS_ORIGINS=http://localhost:3000

# ----- Database -----
# Local dev (default): SQLite. Leave unset to use the local SQLite file.
# DATABASE_URL=sqlite:///./attendance_system.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://attendance:attendance@db:5432/attendance

# ----- Face recognition (optional tuning) -----
# FACE_MATCH_THRESHOLD=0.42
# FACE_DUPLICATE_THRESHOLD=0.50
